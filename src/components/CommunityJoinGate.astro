---
import { communityConfig } from '../config/community';

const community = communityConfig.communityChannel;
---

<dialog
  id="community-join-gate"
  aria-labelledby="community-join-title"
  aria-describedby="community-join-intro"
  aria-modal="true"
  data-community-invite-url={community.url}
  class="m-auto max-h-[calc(100dvh-1rem)] w-[calc(100%-1rem)] max-w-2xl overflow-hidden rounded-3xl border border-white/15 bg-ink-950 p-0 text-left text-white shadow-2xl backdrop:bg-ink-950/88 backdrop:backdrop-blur-sm sm:max-h-[calc(100dvh-2rem)] sm:w-[calc(100%-2rem)]"
>
  <form data-community-gate-form class="flex max-h-[calc(100dvh-1rem)] flex-col sm:max-h-[calc(100dvh-2rem)]">
    <header class="flex shrink-0 items-start justify-between gap-5 border-b border-white/10 px-5 py-5 sm:px-7 sm:py-6">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-limewash">Before you join</p>
        <h2 id="community-join-title" class="mt-2 text-2xl font-black leading-tight text-white sm:text-3xl">Read and agree to the community rules</h2>
        <p id="community-join-intro" class="mt-3 max-w-xl text-sm leading-6 text-braga-100 sm:text-base sm:leading-7">
          You’re joining the <strong class="text-white">{community.groupName}</strong>, part of the <strong class="text-white">{community.name}</strong>.
        </p>
      </div>
      <button type="button" data-community-gate-close aria-label="Close community rules" class="grid h-11 w-11 shrink-0 place-items-center rounded-full border border-white/15 text-2xl leading-none text-braga-100 transition hover:border-limewash/60 hover:text-limewash">×</button>
    </header>

    <div data-community-gate-content class="overscroll-contain overflow-y-auto px-5 py-6 sm:px-7 sm:py-7">
      <section aria-labelledby="community-expectations-title">
        <h3 id="community-expectations-title" class="text-lg font-black text-white">{community.expectationsTitle}</h3>
        <p class="mt-2 text-sm leading-6 text-braga-100 sm:text-base sm:leading-7">{community.introduction}</p>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-braga-100 sm:text-base sm:leading-7">
          {community.principles.map((principle) => (
            <li class="flex gap-3"><span class="mt-[0.65rem] h-1.5 w-1.5 shrink-0 rounded-full bg-limewash" aria-hidden="true"></span><span>{principle}</span></li>
          ))}
        </ul>
      </section>

      <section class="mt-7 border-t border-white/10 pt-6" aria-labelledby="community-eligibility-title">
        <h3 id="community-eligibility-title" class="text-lg font-black text-white">Who can join?</h3>
        <p class="mt-2 text-sm leading-6 text-braga-100 sm:text-base sm:leading-7">{community.eligibility}</p>
      </section>

      <section class="mt-7 border-t border-white/10 pt-6" aria-labelledby="community-member-rules-title">
        <h3 id="community-member-rules-title" class="text-lg font-black text-white">Member expectations</h3>
        <ol class="mt-5 space-y-5">
          {community.expectations.map((expectation, index) => (
            <li class="grid grid-cols-[2rem_1fr] gap-2 text-sm leading-6 sm:text-base sm:leading-7">
              <span class="font-black text-limewash" aria-hidden="true">{index + 1}.</span>
              <div><h4 class="font-black text-white">{expectation.title}</h4><p class="mt-1 text-braga-100">{expectation.body}</p></div>
            </li>
          ))}
        </ol>
      </section>

      <section class="mt-7 grid gap-5 border-t border-white/10 pt-6 sm:grid-cols-2" aria-label="Administration and minors">
        <div>
          <h3 class="font-black text-white">Admin authority</h3>
          <p class="mt-2 text-sm leading-6 text-braga-100">{community.adminAuthority}</p>
        </div>
        <div>
          <h3 class="font-black text-white">Minors in groups</h3>
          <p class="mt-2 text-sm leading-6 text-braga-100">{community.minors}</p>
        </div>
      </section>

      <fieldset class="mt-7 space-y-3 border-t border-white/10 pt-6">
        <legend class="text-lg font-black text-white">Your agreement</legend>
        <label class="mt-4 flex min-h-14 cursor-pointer items-start gap-3 rounded-2xl border border-white/15 bg-white/[0.035] p-4 text-sm leading-6 text-braga-100 transition hover:border-limewash/40">
          <input data-community-rules-consent name="rulesConsent" type="checkbox" required class="mt-1 h-5 w-5 shrink-0 accent-limewash" />
          <span>{community.rulesConsentLabel}</span>
        </label>
        <label class="flex min-h-14 cursor-pointer items-start gap-3 rounded-2xl border border-white/15 bg-white/[0.035] p-4 text-sm leading-6 text-braga-100 transition hover:border-limewash/40">
          <input data-community-legal-consent name="legalConsent" type="checkbox" required class="mt-1 h-5 w-5 shrink-0 accent-limewash" />
          <span>
            {community.inviteConsentLabel} I also agree to the{' '}
            <a class="font-semibold text-limewash underline decoration-limewash/40 underline-offset-2 hover:text-white" href="/terms" target="_blank" rel="noreferrer noopener">Terms and Conditions</a>
            {' '}and{' '}
            <a class="font-semibold text-limewash underline decoration-limewash/40 underline-offset-2 hover:text-white" href="/privacy" target="_blank" rel="noreferrer noopener">Privacy Policy</a>.
          </span>
        </label>
      </fieldset>
    </div>

    <footer class="grid shrink-0 gap-3 border-t border-white/10 bg-ink-950/96 px-5 py-4 sm:grid-cols-[auto_1fr] sm:px-7">
      <button type="button" data-community-gate-close class="btn-secondary order-2 w-full sm:order-1 sm:w-auto">Cancel</button>
      <button type="submit" data-community-gate-submit class="btn-primary order-1 w-full sm:order-2" disabled>{community.openLabel}</button>
    </footer>
  </form>
</dialog>

<script>
  const gateId = 'community-join-gate';

  function getGate() {
    return document.getElementById(gateId) as HTMLDialogElement | null;
  }

  function resetGate(dialog: HTMLDialogElement) {
    const form = dialog.querySelector<HTMLFormElement>('[data-community-gate-form]');
    form?.reset();
    const submit = dialog.querySelector<HTMLButtonElement>('[data-community-gate-submit]');
    if (submit) submit.disabled = true;
  }

  function syncGate(dialog: HTMLDialogElement) {
    const rules = dialog.querySelector<HTMLInputElement>('[data-community-rules-consent]');
    const legal = dialog.querySelector<HTMLInputElement>('[data-community-legal-consent]');
    const submit = dialog.querySelector<HTMLButtonElement>('[data-community-gate-submit]');
    if (submit) submit.disabled = !(rules?.checked && legal?.checked);
  }

  if (!document.documentElement.dataset.communityGateBound) {
    document.documentElement.dataset.communityGateBound = 'true';

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest<HTMLElement>('[data-community-join]');
      if (trigger) {
        event.preventDefault();
        const dialog = getGate();
        if (!dialog) return;
        resetGate(dialog);
        dialog.showModal();
        dialog.querySelector<HTMLButtonElement>('[data-community-gate-close]')?.focus();
        return;
      }

      const close = target.closest<HTMLElement>('[data-community-gate-close]');
      if (close) {
        getGate()?.close();
        return;
      }

      if (target instanceof HTMLDialogElement && target.id === gateId) target.close();
    });

    document.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.closest(`#${gateId}`)) return;
      const dialog = getGate();
      if (dialog) syncGate(dialog);
    });

    document.addEventListener('submit', (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement) || !form.matches('[data-community-gate-form]')) return;
      event.preventDefault();
      const dialog = getGate();
      if (!dialog) return;
      syncGate(dialog);
      const submit = dialog.querySelector<HTMLButtonElement>('[data-community-gate-submit]');
      if (submit?.disabled) return;
      const inviteUrl = dialog.dataset.communityInviteUrl;
      if (!inviteUrl) return;
      dialog.close();
      window.location.assign(inviteUrl);
    });
  }
</script>
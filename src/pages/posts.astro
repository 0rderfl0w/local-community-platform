---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdeaFeed from '../components/ideas/IdeaFeed';
import { communityConfig, communityPageTitle } from '../config/community';
import { socialCardPath } from '../lib/socialCards';
---
<BaseLayout
  title={communityPageTitle('Posts')}
  description={`Ideas, resources, and perspectives from the ${communityConfig.name} community.`}
  socialImage={socialCardPath('posts')}
  socialImageAlt={`Community posts from ${communityConfig.name}`}
>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <header class="max-w-3xl">
      <h1 class="text-4xl font-black text-white">Community posts</h1>
      <p class="mt-4 text-slate-300">Ideas, resources, and perspectives from the {communityConfig.name} community. Upvotes only.</p>
    </header>
    <div class="mt-8">
      <IdeaFeed layout="sidebar" persistFilters client:load />
    </div>
  </section>
</BaseLayout>

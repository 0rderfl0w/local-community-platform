---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberDirectory from '../../components/profile/MemberDirectory';
import { communityConfig, communityPageTitle } from '../../config/community';
import { socialCardPath } from '../../lib/socialCards';
---
<BaseLayout
  title={communityPageTitle('Members')}
  description={`Public profiles from members who opted into the ${communityConfig.name} directory.`}
  socialImage={socialCardPath('members')}
  socialImageAlt={`Members of ${communityConfig.name}`}
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-black text-white">Members</h1>
    <p class="mt-4 text-slate-300">Public profiles from members who opted into the directory.</p>
    <div class="mt-8">
      <MemberDirectory client:load />
    </div>
  </section>
</BaseLayout>

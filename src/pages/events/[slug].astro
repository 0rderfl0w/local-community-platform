---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventDetail from '../../components/events/EventDetail';
import { communityConfig, communityPageTitle } from '../../config/community';
import { publicRecordLookup } from '../../lib/public-server';
import { normalizeSocialText, normalizeSocialTitle, socialCardPath } from '../../lib/socialCards';
import type { Event } from '../../lib/types';

export const prerender = false;

type EventPageRecord = Pick<Event, 'slug' | 'title' | 'description' | 'starts_at' | 'location_name' | 'updated_at'>;
const slug = Astro.params.slug ?? '';
const validSlug = /^[a-z0-9][a-z0-9-]{2,159}$/.test(slug);
const lookup = validSlug
  ? await publicRecordLookup<EventPageRecord>('events', 'slug', slug, 'slug,title,description,starts_at,location_name,updated_at')
  : { available: true, data: null };
const event = lookup.data;
if (!validSlug || (lookup.available && !event)) Astro.response.status = 404;

const title = event ? communityPageTitle(event.title) : communityPageTitle('Event');
const description = event
  ? normalizeSocialText(event.description, 180) || `A community event from ${communityConfig.name}.`
  : `A community event from ${communityConfig.name}.`;
const socialImageAlt = event
  ? `${normalizeSocialTitle(event.title, 120)}, an event from ${communityConfig.name}`
  : `Community event from ${communityConfig.name}`;
const socialImage = event ? socialCardPath('event', slug, event.updated_at) : socialCardPath('events');
---
<BaseLayout
  title={title}
  description={description}
  socialImage={socialImage}
  socialImageAlt={socialImageAlt}
  socialType="article"
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <EventDetail slug={slug} client:load />
  </section>
</BaseLayout>

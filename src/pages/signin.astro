---
import BaseLayout from '../layouts/BaseLayout.astro';
import InviteEmailForm from '../components/auth/InviteEmailForm';
import { communityConfig, communityPageTitle } from '../config/community';
---
<BaseLayout title={communityPageTitle('Sign in')} description={`Sign in to your existing ${communityConfig.name} account with a secure email link.`}>
  <section class="mx-auto max-w-2xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-limewash">Existing members</p>
    <h1 class="mt-4 text-4xl font-black text-white">Sign in</h1>
    <div class="mt-8">
      <InviteEmailForm mode="signin" client:load />
    </div>
  </section>
</BaseLayout>

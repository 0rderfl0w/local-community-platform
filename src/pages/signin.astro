---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignInTabs from '../components/auth/SignInTabs';
import { communityConfig, communityPageTitle } from '../config/community';
---
<BaseLayout title={communityPageTitle('Member access')} description={`Sign in to ${communityConfig.name} or get a private invitation to join.`}>
  <section class="mx-auto max-w-2xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-limewash">{communityConfig.name}</p>
    <h1 class="mt-4 text-4xl font-black text-white">Member access</h1>
    <div class="mt-8">
      <SignInTabs client:load />
    </div>
  </section>
</BaseLayout>
